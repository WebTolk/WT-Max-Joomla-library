<?xml version="1.0" encoding="utf-8"?>
<extension version="4.0" type="plugin" group="system" method="upgrade">
	<name>System - WT Max</name>
	<author>Sergey Tolkachyov</author>
	<creationDate>__DEPLOY_DATE__</creationDate>
	<copyright>Copyright (c) 2026 Sergey Tolkachyov. All rights reserved.</copyright>
	<license>GNU General Public License version 3 or later; see LICENSE.txt</license>
	<authorEmail>info@web-tolk.ru</authorEmail>
	<authorUrl>https://web-tolk.ru</authorUrl>
	<version>__DEPLOY_VERSION__</version>
	<description>PLG_WTMAX_DESC</description>
	<namespace path="src">Joomla\Plugin\System\Wtmax</namespace>
	<files>
		<filename plugin="wtmax">wtmax.xml</filename>
		<folder>services</folder>
		<folder>src</folder>
	</files>
	<languages folder="language" client="administrator">
		<language tag="en-GB">en-GB/plg_system_wtmax.ini</language>
		<language tag="en-GB">en-GB/plg_system_wtmax.sys.ini</language>
		<language tag="ru-RU">ru-RU/plg_system_wtmax.ini</language>
		<language tag="ru-RU">ru-RU/plg_system_wtmax.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="basic">
				<field addfieldprefix="Joomla\Plugin\System\Wtmax\Field" type="plugininfo" name="plugininfo"/>
				<field addfieldprefix="Webtolk\Wtmax\Field" type="connectionstatus" name="connectionstatus"/>
				<field type="password"
					name="bot_token"
					label="PLG_WTMAX_BOT_TOKEN"
					description="PLG_WTMAX_BOT_TOKEN_DESC"
					maxlength="512"
					filter="raw"/>
				<field type="radio"
					name="log_separate_file"
					label="PLG_WTMAX_LOG_SEPARATE_FILE"
					description="PLG_WTMAX_LOG_SEPARATE_FILE_DESC"
					layout="joomla.form.field.radio.switcher"
					default="0">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field type="text"
					name="log_file"
					label="PLG_WTMAX_LOG_FILE"
					description="PLG_WTMAX_LOG_FILE_DESC"
					filter="raw"
					showon="log_separate_file:1"/>
			</fieldset>
		</fields>
	</config>
</extension>
